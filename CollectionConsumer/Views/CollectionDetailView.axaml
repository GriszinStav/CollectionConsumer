<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CollectionConsumer.Views.Converters"
             x:Class="CollectionConsumer.Views.CollectionDetailView"
             x:CompileBindings="False">
    <UserControl.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
        <conv:RarityToColorConverter x:Key="RarityToColor" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Button.detail-action">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF6F00" Offset="0" />
                    <GradientStop Color="#FFA726" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Style.Animations>
                <Animation Duration="0:0:0.15">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.05" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.05" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.card-item">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BoxShadow" Value="0 2 8 0 rgba(0,0,0,0.1)" />
            <Style.Animations>
                <Animation Duration="0:0:0.3">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="TranslateTransform.Y" Value="15" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="TranslateTransform.Y" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая панель – детальная информация о выбранной карточке -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="16" Margin="5,5,10,5" 
                Padding="15" BoxShadow="0 2 10 0 rgba(0,0,0,0.08)">
            <StackPanel>
                <!-- Изображение -->
                <Image Source="{Binding SelectedCard.ImagePath, Converter={StaticResource PathToImage}}" 
                       Width="140" Height="140" Margin="0,0,0,10" 
                       HorizontalAlignment="Center" />
                <!-- Название -->
                <TextBlock Text="{Binding SelectedCard.Name}" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,5" />
                <!-- Редкость с цветным фоном -->
                <Border Padding="8,4" HorizontalAlignment="Center" CornerRadius="20"
                        Background="{Binding SelectedCard.Rarity, Converter={StaticResource RarityToColor}}">
                    <TextBlock Text="{Binding SelectedCard.Rarity}" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextColor}" />
                </Border>
                <!-- Цена -->
                <TextBlock Text="{Binding SelectedCard.Price, StringFormat='&#x426;&#x435;&#x43D;&#x430;: {0:C}'}" 
                           FontSize="16" Margin="0,10,0,5" />
                <!-- Дата получения -->
                <TextBlock Text="{Binding SelectedCard.AcquisitionDate, StringFormat='&#x41F;&#x43E;&#x43B;&#x443;&#x447;&#x435;&#x43D;&#x430;: {0:d}'}" 
                           FontSize="16" Margin="0,0,0,15" />
                <!-- Кнопка удаления -->
                <Button Command="{Binding RemoveCardCommand}" Classes="detail-action" 
                        Background="#E53935" HorizontalAlignment="Stretch">
                    &#x423;&#x434;&#x430;&#x43B;&#x438;&#x442;&#x44C; &#x43A;&#x430;&#x440;&#x442;&#x443;
                </Button>
            </StackPanel>
        </Border>

        <!-- Правая часть – список карточек -->
        <DockPanel Grid.Column="1" Margin="10,5,5,5">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="{Binding Collection.Name}" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="{Binding Collection.Cards.Count}" Margin="20,0,0,0" FontSize="18" 
                           Foreground="{DynamicResource SecondaryText}" />
                <Button Command="{Binding AddCardCommand}" Margin="20,0,0,0" 
                        Background="{DynamicResource PrimaryColor}" CornerRadius="20" 
                        Padding="15,10" FontWeight="Bold">
                    &#x2B; &#x414;&#x43E;&#x431;&#x430;&#x432;&#x438;&#x442;&#x44C; &#x43A;&#x430;&#x440;&#x442;&#x43E;&#x447;&#x43A;&#x443;
                </Button>
            </StackPanel>
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="130" Height="170" Margin="8" Classes="card-item">
                                <Button Command="{Binding $parent[ItemsControl].DataContext.SelectCardCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" 
                                        Padding="5">
                                    <StackPanel>
                                        <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}" 
                                               Width="90" Height="90" Margin="0,5" />
                                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" 
                                                   FontWeight="SemiBold" TextWrapping="Wrap" 
                                                   MaxWidth="110" FontSize="13" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>