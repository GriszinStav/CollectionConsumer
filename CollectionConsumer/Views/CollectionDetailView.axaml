<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CollectionConsumer.Views.Converters"
             x:Class="CollectionConsumer.Views.CollectionDetailView"
             x:CompileBindings="False">
	<UserControl.Resources>
		<conv:PathToImageConverter x:Key="PathToImage" />
		<conv:RarityToColorConverter x:Key="RarityToColor" />
	</UserControl.Resources>
	<UserControl.Styles>
		<Style Selector="Button.detail-action">
			<Setter Property="Background" Value="{DynamicResource PrimaryColor}" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="12,8" />
			<Style.Animations>
				<Animation Duration="0:0:0.15">
					<KeyFrame Cue="0%">
						<Setter Property="ScaleTransform.ScaleX" Value="1" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="ScaleTransform.ScaleX" Value="1.05" />
						<Setter Property="ScaleTransform.ScaleY" Value="1.05" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="Border.card-item">
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="ClipToBounds" Value="True" />
			<Setter Property="BoxShadow" Value="0 2 8 0 rgba(0,0,0,0.1)" />
			<Style.Animations>
				<Animation Duration="0:0:0.3">
					<KeyFrame Cue="0%">
						<Setter Property="Opacity" Value="0" />
						<Setter Property="TranslateTransform.Y" Value="15" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="Opacity" Value="1" />
						<Setter Property="TranslateTransform.Y" Value="0" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="Border.card-text-overlay">
			<Setter Property="Background" Value="#80000000" />
			<Setter Property="CornerRadius" Value="0,0,12,12" />
			<Setter Property="Padding" Value="6,4" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Bottom" />
		</Style>
		<Style Selector="Border.detail-text-overlay">
			<Setter Property="Background" Value="#80000000" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="12,10" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Bottom" />
			<Setter Property="Margin" Value="0,0,0,55" />
			<!-- отступ снизу для кнопки -->
		</Style>
	</UserControl.Styles>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- Левая панель -->
		<Border Grid.Column="0" CornerRadius="16" Margin="5,5,10,5"
                BoxShadow="0 2 10 rgba(0,0,0,0.08)" ClipToBounds="True">
			<Grid>
				<Image Source="{Binding SelectedCard.ImagePath, Converter={StaticResource PathToImage}}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
				<!-- Текст поверх изображения, с отступом снизу -->
				<Border Classes="detail-text-overlay">
					<StackPanel>
						<TextBlock Text="{Binding SelectedCard.Name}" FontSize="20" FontWeight="Bold"
                                   Foreground="White" />
						<TextBlock Text="{Binding SelectedCard.Rarity}" FontSize="15"
                                   Foreground="#DDDDDD" />
						<TextBlock Foreground="#DDDDDD" FontSize="14">
							<TextBlock.Text>
								<MultiBinding StringFormat="{}Цена: {0:C}">
									<Binding Path="SelectedCard.Price" />
								</MultiBinding>
							</TextBlock.Text>
						</TextBlock>
						<TextBlock Foreground="#DDDDDD" FontSize="14">
							<TextBlock.Text>
								<MultiBinding StringFormat="{}Получена: {0:d}">
									<Binding Path="SelectedCard.AcquisitionDate" />
								</MultiBinding>
							</TextBlock.Text>
						</TextBlock>
					</StackPanel>
				</Border>
				<!-- Кнопка удаления внизу, не перекрывает текст -->
				<Button Command="{Binding RemoveCardCommand}"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Background="#E53935" CornerRadius="12"
                        Padding="16,8" Margin="0,0,0,12"
                        Classes="detail-action"
                        FontWeight="Bold"
                        Height="36">
					&#x423;&#x434;&#x430;&#x43B;&#x438;&#x442;&#x44C;
				</Button>
			</Grid>
		</Border>

		<!-- Правая часть -->
		<DockPanel Grid.Column="1" Margin="10,5,5,5">
			<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
				<TextBlock Text="{Binding Collection.Name}" FontSize="28" FontWeight="Bold" />
				<TextBlock Text="{Binding Collection.Cards.Count}" Margin="20,0,0,0" FontSize="18"
                           Foreground="{DynamicResource SecondaryText}" />
				<Button Command="{Binding AddCardCommand}" Margin="20,0,0,0" Classes="detail-action"
                        Background="{DynamicResource PrimaryColor}">
					&#x2B; &#x414;&#x43E;&#x431;&#x430;&#x432;&#x438;&#x442;&#x44C; &#x43A;&#x430;&#x440;&#x442;&#x43E;&#x447;&#x43A;&#x443;
				</Button>
			</StackPanel>
			<ScrollViewer>
				<ItemsControl ItemsSource="{Binding Cards}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Width="130" Height="170" Margin="8"
                                    Command="{Binding $parent[ItemsControl].DataContext.SelectCardCommand}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch">
								<Border Classes="card-item">
									<Grid>
										<Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch" />
										<Border Classes="card-text-overlay">
											<TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       HorizontalAlignment="Center" />
										</Border>
									</Grid>
								</Border>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</DockPanel>
	</Grid>
</UserControl>