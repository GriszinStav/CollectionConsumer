<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CollectionConsumer.Views.Dialogs.RemoveCollectionDialog"
        Title="Удаление коллекции"
        Width="400"
        Height="180"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">
	<Window.Styles>
		<Style Selector="Button.dialog-delete">
			<Setter Property="Background">
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
					<GradientStop Color="#D32F2F" Offset="0" />
					<GradientStop Color="#E53935" Offset="1" />
				</LinearGradientBrush>
			</Setter>
			<Setter Property="Foreground" Value="White" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="FontWeight" Value="Bold" />
			<Style.Animations>
				<Animation Duration="0:0:0.15">
					<KeyFrame Cue="0%">
						<Setter Property="ScaleTransform.ScaleX" Value="1" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="ScaleTransform.ScaleX" Value="1.05" />
						<Setter Property="ScaleTransform.ScaleY" Value="1.05" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="Button.dialog-cancel">
			<Setter Property="Background">
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
					<GradientStop Color="#757575" Offset="0" />
					<GradientStop Color="#9E9E9E" Offset="1" />
				</LinearGradientBrush>
			</Setter>
			<Setter Property="Foreground" Value="White" />
			<Setter Property="CornerRadius" Value="8" />
			<Style.Animations>
				<Animation Duration="0:0:0.15">
					<KeyFrame Cue="0%">
						<Setter Property="ScaleTransform.ScaleX" Value="1" />
						<Setter Property="ScaleTransform.ScaleY" Value="1" />
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="ScaleTransform.ScaleX" Value="1.05" />
						<Setter Property="ScaleTransform.ScaleY" Value="1.05" />
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
	</Window.Styles>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
			<TextBlock FontSize="16" TextWrapping="Wrap"
                       Text="{Binding Message}"
                       HorizontalAlignment="Center" />
		</StackPanel>
		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20" Spacing="10">
			<Button Command="{Binding DeleteCommand}" MinWidth="80" Classes="dialog-delete">Удалить</Button>
			<Button Command="{Binding CancelCommand}" MinWidth="80" Classes="dialog-cancel">Отмена</Button>
		</StackPanel>
	</Grid>
</Window>