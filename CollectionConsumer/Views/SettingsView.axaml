<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CollectionConsumer.Views.SettingsView"
             x:CompileBindings="False">
    <StackPanel Margin="20">
        <TextBlock Text="&#x41D;&#x430;&#x441;&#x442;&#x440;&#x43E;&#x439;&#x43A;&#x438;" FontSize="24" />
        <TextBlock Text="&#x412;&#x44B;&#x431;&#x435;&#x440;&#x438;&#x442;&#x435; &#x442;&#x435;&#x43C;&#x443;:" Margin="0,20,0,5" />
        <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}" Width="200" />
    </StackPanel>
</UserControl>