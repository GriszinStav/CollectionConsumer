<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CollectionConsumer.Views.MainWindow"
        Title="CollectionConsumer"
        Width="900" Height="600"
        x:CompileBindings="False">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Command="{Binding ShowCollectionsCommand}">&#x41C;&#x43E;&#x438; &#x43A;&#x43E;&#x43B;&#x43B;&#x435;&#x43A;&#x446;&#x438;&#x438;</Button>
            <Button Command="{Binding ShowSettingsCommand}" Margin="10,0,0,0">&#x41D;&#x430;&#x441;&#x442;&#x440;&#x43E;&#x439;&#x43A;&#x438;</Button>
        </StackPanel>
        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>