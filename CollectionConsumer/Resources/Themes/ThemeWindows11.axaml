<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F0F6FC" Offset="0" />
        <GradientStop Color="#D0E4F5" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4" />
    <SolidColorBrush x:Key="PrimaryDark" Color="#005A9E" />
    <SolidColorBrush x:Key="PrimaryLight" Color="#60CDFF" />
    <SolidColorBrush x:Key="TextColor" Color="#000000" />
    <SolidColorBrush x:Key="SecondaryText" Color="#707070" />
    <SolidColorBrush x:Key="DividerColor" Color="#E0E0E0" />
</ResourceDictionary>