                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="White" />
    <SolidColorBrush x:Key="ButtonBackground" Color="#EEEEEE" />
    <SolidColorBrush x:Key="BorderColor" Color="Gray" />
</ResourceDictionary>