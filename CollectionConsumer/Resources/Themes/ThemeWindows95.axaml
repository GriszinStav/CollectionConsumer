<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#008080" Offset="0" />
        <GradientStop Color="#005050" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBackground" Color="#C0C0C0" />
    <SolidColorBrush x:Key="PrimaryColor" Color="#800000" />
    <SolidColorBrush x:Key="PrimaryDark" Color="#400000" />
    <SolidColorBrush x:Key="PrimaryLight" Color="#C08080" />
    <SolidColorBrush x:Key="TextColor" Color="#000000" />
    <SolidColorBrush x:Key="SecondaryText" Color="#404040" />
    <SolidColorBrush x:Key="DividerColor" Color="#808080" />
</ResourceDictionary>